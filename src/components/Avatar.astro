---
// SVG Avatar component for the About page
---

<div class="avatar-wrapper">
	<svg viewBox="0 0 200 200" class="avatar-svg" xmlns="http://www.w3.org/2000/svg">
		<defs>
			<!-- Background Gradient -->
			<linearGradient id="bg-grad" x1="0%" y1="0%" x2="100%" y2="100%">
				<stop offset="0%" stop-color="#4f46e5" />   <!-- Indigo -->
				<stop offset="50%" stop-color="#8b5cf6" />  <!-- Violet -->
				<stop offset="100%" stop-color="#ec4899" /> <!-- Pink -->
			</linearGradient>

			<!-- Ring/Aura Gradient -->
			<linearGradient id="ring-grad" x1="0%" y1="100%" x2="100%" y2="0%">
				<stop offset="0%" stop-color="#f43f5e" />   <!-- Rose -->
				<stop offset="100%" stop-color="#3b82f6" />  <!-- Blue -->
			</linearGradient>

			<!-- Glass Reflection Gradient -->
			<linearGradient id="glass-reflection" x1="0%" y1="0%" x2="100%" y2="100%">
				<stop offset="0%" stop-color="#ffffff" stop-opacity="0.6" />
				<stop offset="30%" stop-color="#ffffff" stop-opacity="0.1" />
				<stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
			</linearGradient>

			<!-- Lens Gradient -->
			<linearGradient id="lens-grad" x1="0%" y1="0%" x2="0%" y2="100%">
				<stop offset="0%" stop-color="#38bdf8" stop-opacity="0.25" />
				<stop offset="100%" stop-color="#a855f7" stop-opacity="0.1" />
			</linearGradient>

			<!-- Drop Shadow for avatar -->
			<filter id="shadow" x="-10%" y="-10%" width="120%" height="120%">
				<feDropShadow dx="0" dy="8" stdDeviation="6" flood-color="#0f172a" flood-opacity="0.25" />
			</filter>

			<!-- Glow Filters for neon symbols -->
			<filter id="glow-cyan" x="-20%" y="-20%" width="140%" height="140%">
				<feGaussianBlur stdDeviation="3" result="blur" />
				<feMerge>
					<feMergeNode in="blur" />
					<feMergeNode in="SourceGraphic" />
				</feMerge>
			</filter>
			<filter id="glow-rose" x="-20%" y="-20%" width="140%" height="140%">
				<feGaussianBlur stdDeviation="3" result="blur" />
				<feMerge>
					<feMergeNode in="blur" />
					<feMergeNode in="SourceGraphic" />
				</feMerge>
			</filter>
		</defs>

		<!-- Glowing outer circle -->
		<circle cx="100" cy="100" r="94" fill="none" stroke="url(#ring-grad)" stroke-width="2" class="glow-ring" />

		<!-- Main Background Circle -->
		<circle cx="100" cy="100" r="90" fill="url(#bg-grad)" filter="url(#shadow)" class="main-bg" />

		<!-- Abstract Code Lines / Tech Grid in background of avatar -->
		<g class="bg-patterns" opacity="0.15">
			<line x1="40" y1="60" x2="70" y2="60" stroke="#ffffff" stroke-width="2" stroke-linecap="round" />
			<line x1="40" y1="70" x2="60" y2="70" stroke="#ffffff" stroke-width="2" stroke-linecap="round" />
			<line x1="130" y1="130" x2="160" y2="130" stroke="#ffffff" stroke-width="2" stroke-linecap="round" />
			<line x1="140" y1="140" x2="160" y2="140" stroke="#ffffff" stroke-width="2" stroke-linecap="round" />
			<circle cx="150" cy="70" r="3" fill="#ffffff" />
			<circle cx="50" cy="130" r="4" fill="#ffffff" />
		</g>

		<!-- Avatar Character Group -->
		<g class="character">
			<!-- Neck -->
			<path d="M 90 130 L 90 145 L 110 145 L 110 130 Z" fill="#fce7f3" />
			<!-- Neck Shadow -->
			<path d="M 90 130 Q 100 136 110 130 L 110 135 Q 100 140 90 135 Z" fill="#db2777" opacity="0.15" />

			<!-- Hoodie / Clothing -->
			<path d="M 54 180 C 54 150, 75 140, 100 140 C 125 140, 146 150, 146 180 Z" fill="#1e1b4b" />
			<path d="M 85 140 L 100 160 L 115 140 Z" fill="#312e81" /> <!-- Inner shirt / hood shadow -->
			<path d="M 100 160 L 95 180 M 100 160 L 105 180" stroke="#a5b4fc" stroke-width="2" stroke-linecap="round" /> <!-- Drawstrings -->

			<!-- Head / Face -->
			<rect x="70" y="65" width="60" height="70" rx="30" fill="#fce7f3" /> <!-- Skin: soft pinkish/peach -->
			
			<!-- Cheeks (Blush) -->
			<circle cx="78" cy="112" r="5" fill="#f43f5e" opacity="0.25" />
			<circle cx="122" cy="112" r="5" fill="#f43f5e" opacity="0.25" />

			<!-- Mouth -->
			<path d="M 94 116 Q 100 122 106 116" stroke="#4f46e5" stroke-width="2.5" stroke-linecap="round" fill="none" />

			<!-- Eyes -->
			<circle cx="85" cy="98" r="2" fill="#1e1b4b" />
			<circle cx="115" cy="98" r="2" fill="#1e1b4b" />

			<!-- Glasses -->
			<g class="glasses">
				<!-- Left frame -->
				<circle cx="85" cy="98" r="14" fill="url(#lens-grad)" stroke="#1e1b4b" stroke-width="3" />
				<!-- Right frame -->
				<circle cx="115" cy="98" r="14" fill="url(#lens-grad)" stroke="#1e1b4b" stroke-width="3" />
				<!-- Bridge -->
				<path d="M 99 98 L 101 98" stroke="#1e1b4b" stroke-width="3.5" stroke-linecap="round" />
				<!-- Hinges / Temples -->
				<path d="M 71 98 L 66 98" stroke="#1e1b4b" stroke-width="3" stroke-linecap="round" />
				<path d="M 129 98 L 134 98" stroke="#1e1b4b" stroke-width="3" stroke-linecap="round" />
				<!-- Reflections (slanted highlights) -->
				<path d="M 77 90 L 87 100" stroke="#ffffff" stroke-width="2" stroke-linecap="round" opacity="0.6" class="glass-reflection-line" />
				<path d="M 107 90 L 117 100" stroke="#ffffff" stroke-width="2" stroke-linecap="round" opacity="0.6" class="glass-reflection-line" />
			</g>

			<!-- Hair / Haircut -->
			<path d="M 70 75 C 68 55, 90 42, 108 45 C 122 47, 132 58, 130 75 C 126 73, 122 73, 118 75 C 114 62, 90 58, 82 72 C 78 72, 74 73, 70 75 Z" fill="#1e1b4b" />
			<!-- Hair sideburns -->
			<path d="M 70 75 L 68 85 L 73 85 Z" fill="#1e1b4b" />
			<path d="M 130 75 L 132 85 L 127 85 Z" fill="#1e1b4b" />
		</g>

		<!-- Foreground / Floating elements: Glowing Code brackets -->
		<g class="floating-elements">
			<!-- Left Braces '{' -->
			<text x="12" y="90" font-family="'Outfit', 'Inter', sans-serif" font-size="22" font-weight="bold" fill="#38bdf8" filter="url(#glow-cyan)" class="float-code-left">&#123;</text>
			<!-- Right Braces '}' -->
			<text x="170" y="120" font-family="'Outfit', 'Inter', sans-serif" font-size="22" font-weight="bold" fill="#ec4899" filter="url(#glow-rose)" class="float-code-right">&#125;</text>
		</g>
	</svg>
</div>

<style>
	.avatar-wrapper {
		position: relative;
		width: 200px;
		height: 200px;
		margin: 0 auto 2rem auto;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.avatar-svg {
		width: 100%;
		height: 100%;
		overflow: visible;
		filter: drop-shadow(0 8px 16px rgba(99, 102, 241, 0.15));
		transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
		animation: float 6s ease-in-out infinite;
	}

	/* Float keyframes */
	@keyframes float {
		0%, 100% {
			transform: translateY(0px) rotate(0deg);
		}
		50% {
			transform: translateY(-8px) rotate(1deg);
		}
	}

	/* Glow Ring pulsing animation */
	.glow-ring {
		transform-origin: center;
		animation: pulse-ring 4s ease-in-out infinite alternate;
		stroke-dasharray: 600;
		stroke-dashoffset: 0;
		transition: stroke-dashoffset 0.8s ease;
	}

	@keyframes pulse-ring {
		0% {
			transform: scale(0.98);
			opacity: 0.5;
		}
		100% {
			transform: scale(1.02);
			opacity: 0.95;
		}
	}

	/* Floating code signs */
	.float-code-left {
		animation: float-left 5s ease-in-out infinite;
		transform-origin: 20px 85px;
	}

	@keyframes float-left {
		0%, 100% {
			transform: translate(0, 0) scale(1) rotate(0deg);
			opacity: 0.8;
		}
		50% {
			transform: translate(-4px, -6px) scale(1.1) rotate(-8deg);
			opacity: 1;
		}
	}

	.float-code-right {
		animation: float-right 5.5s ease-in-out infinite;
		transform-origin: 180px 115px;
	}

	@keyframes float-right {
		0%, 100% {
			transform: translate(0, 0) scale(1) rotate(0deg);
			opacity: 0.8;
		}
		50% {
			transform: translate(4px, 6px) scale(1.1) rotate(8deg);
			opacity: 1;
		}
	}

	/* Micro-animations on hover */
	.avatar-wrapper:hover .avatar-svg {
		transform: translateY(-4px) scale(1.05);
		filter: drop-shadow(0 16px 24px rgba(99, 102, 241, 0.25));
	}

	.avatar-wrapper:hover .glow-ring {
		stroke-dashoffset: 150;
		animation: pulse-ring 1s ease-in-out infinite alternate;
	}

	/* Interactive glasses reflection shift */
	.glass-reflection-line {
		transition: transform 0.4s ease-out;
	}

	.avatar-wrapper:hover .glass-reflection-line {
		transform: translate(3px, -3px);
	}

	/* Pulse keyframes for patterns */
	.bg-patterns circle, .bg-patterns line {
		animation: pattern-pulse 3s ease-in-out infinite alternate;
	}

	@keyframes pattern-pulse {
		0% {
			opacity: 0.3;
		}
		100% {
			opacity: 0.8;
		}
	}
</style>
